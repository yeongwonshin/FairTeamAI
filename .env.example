# FairTeam AI local configuration
# Copy this file to .env and add your own values.
# Never commit the real .env file.

# Optional OpenAI features: structured meeting analysis and AI review briefs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2

# Optional CLI behavior
FAIRTEAM_USE_LLM=false

# Optional GitHub ingestion token for private repositories or higher rate limits
GITHUB_TOKEN=
